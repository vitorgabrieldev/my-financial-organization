{
  "name": "api.financial",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env.local --import tsx src/dev/server.ts",
    "dev:vercel": "vercel dev --yes --listen 127.0.0.1:3001",
    "build": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "sdk:generate": "npm run openapi:export && openapi --input sdk/openapi.json --output sdk/generated --client fetch --useUnionTypes"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.9.2",
    "@vercel/node": "^5.4.0",
    "@vitest/coverage-v8": "^4.0.7",
    "eslint": "^9.39.1",
    "globals": "^17.0.0",
    "openapi-typescript-codegen": "^0.29.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vercel": "^49.0.0",
    "vitest": "^4.0.7",
    "yarn": "^1.22.22"
  }
}
